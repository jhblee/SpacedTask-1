{
  "name": "spacedtask-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,html}\"",
    "rebuild:node": "node scripts/sqlite-swap.js node",
    "rebuild:electron": "node scripts/sqlite-swap.js electron",
    "test": "npm run rebuild:node && npm run test --workspaces --if-present",
    "test:coverage": "npm run rebuild:node && npm run test:coverage --workspaces --if-present",
    "test:e2e": "playwright test",
    "start": "npm run rebuild:electron && node scripts/start.js",
    "build": "npm run build -w packages/shared && npm run build -w packages/db && npm run build -w apps/main && npm run build -w apps/renderer",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
